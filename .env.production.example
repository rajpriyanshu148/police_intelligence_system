# Public domain. Point its A/AAAA DNS record to the server before deployment.
CADDY_DOMAIN=app.example.com
CADDY_EMAIL=admin@example.com

# PostgreSQL: use long, unique values. Do not commit the copied .env.production.
POSTGRES_DB=aipas
POSTGRES_USER=aipas
POSTGRES_PASSWORD=replace_with_a_long_random_database_password

# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_a_long_random_jwt_secret

# JSON list, restricted to the public frontend origin.
CORS_ORIGINS=["https://app.example.com"]

# First install only. Remove these five entries after the first successful start.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_BADGE_NUMBER=ADMIN-001
BOOTSTRAP_ADMIN_DEPARTMENT=Administration
BOOTSTRAP_ADMIN_PASSWORD=replace_with_a_strong_initial_admin_password
