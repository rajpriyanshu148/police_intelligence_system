# =========================================================================
# AIPAS (AI Police Assistance System) Environment Settings Template
# =========================================================================

# --- Application Configuration ---
APP_NAME="Agentic AI Police Intelligence and Assistance System"
APP_DEBUG=true
APP_HOST="127.0.0.1"
APP_PORT=8000

# --- Security & Session Authentication ---
# JWT token signature secret key (Keep private in production)
JWT_SECRET_KEY="POLICE_INTEL_SUPER_SECRET_KEY_JWT"

# --- Centralized Logging Configuration ---
# Standard levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"
LOG_FORMAT="<green>{time:YYYY-MM-DD HH:mm:ss}</green> | <level>{level:8}</level> | <cyan>{name}</cyan>:<cyan>{function}</cyan>:<cyan>{line}</cyan> - <level>{message}</level>"
LOG_FILE="logs/police_system.log"

# --- Database ---
# For local SQLite: sqlite:///police_intel.db
# For PostgreSQL: postgresql://user:password@localhost:5432/police_db
DATABASE_URL="sqlite:///police_intel.db"

# --- AI Service Configuration ---
# Set to 'false' to enable neural transformers inference (requires GPU)
USE_SIMULATION=true
# Base model name or local path for transformers library
MODEL_NAME_OR_PATH="Qwen/Qwen2.5-3B-Instruct"
# Target hardware acceleration device: 'cpu' or 'cuda'
MODEL_DEVICE="cpu"

# --- Fine-Tuning LoRA Settings ---
LORA_R=8
LORA_ALPHA=16
LORA_DROPOUT=0.05
# JSON array representation of target modules
LORA_TARGET_MODULES='["q_proj", "v_proj", "k_proj", "o_proj"]'

# --- Fine-Tuning Training Parameters ---
MODEL_TRAINING_EPOCHS=3
MODEL_TRAINING_BATCH_SIZE=2
MODEL_TRAINING_LEARNING_RATE=0.0002
MODEL_TRAINING_OUTPUT_DIR="models/adapters"

# --- Vector Store & FAISS Configuration ---
# Folder path where FAISS indexes are saved
VECTOR_STORE_INDEX_PATH="data/faiss_index"
# Embedding model name from sentence-transformers package
VECTOR_STORE_EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"

# --- Retrieval-Augmented Generation (RAG) Weights ---
RAG_TOP_K=3
RAG_SOP_WEIGHT=0.5
RAG_BNS_WEIGHT=0.5
